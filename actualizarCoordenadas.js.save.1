// --- 5. FUNCIÓN PARA OBTENER COORDENADAS (usando fetch nativo) ---
async function obtenerCoordenadas(nombreBarrio) {
    const municipio = 'Copacabana, Antioquia, Colombia';
    const query = `${nombreBarrio}, ${municipio}`;
    const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`;

    console.log(`   🔍 Buscando: ${query}`);

    try {
        const response = await fetch(url, {
            headers: {
                'User-Agent': 'MiAppDeBarrios/1.0 (tu-email@ejemplo.com)'
            }
        });
        const data = await response.json();

        if (data && data.length > 0) {
            const { lat, lon } = data[0];
            console.log(`   ✅ Encontrado: (${lat}, ${lon})`);
            return { lat: parseFloat(lat), lon: parseFloat(lon) };
        } else {
            console.log(`   ⚠️  No encontrado`);
            return { lat: 'NO_ENCONTRADO', lon: 'NO_ENCONTRADO' };
        }
    } catch (error) {
        console.error(`   ❌ Error en la búsqueda:`, error.message);
        return { lat: 'ERROR', lon: 'ERROR' };
    }
}

// --- 6. FUNCIÓN PARA ESCRIBIR EN GOOGLE SHEETS ---
async function escribirEnGoogleSheets(auth, filas) {
    const sheets = google.sheets({ version: 'v4', auth });
    
    try {
        const response = await sheets.spreadsheets.values.append({
            spreadsheetId: SPREADSHEET_ID,
            range: `${SHEET_NAME}!A:D`,
            valueInputOption: 'USER_ENTERED',
            resource: { values: filas },
        });
        console.log(`✅ ${response.data.updates.updatedCells} celdas actualizadas en Google Sheets.`);
    } catch (err) {
        console.error('❌ Error al escribir en Google Sheets:', err.message);
    }
}

// --- 7. FUNCIÓN PRINCIPAL ---
async function main() {
    console.log('🚀 Iniciando proceso de actualización de coordenadas...');

    const barrios = prepararListaDeBarrios();
    console.log(`📋 Se procesarán ${barrios.length} barrios.\n`);

    const filasParaSheets = [['BARRIO', 'LAT', 'LONG', 'TARIFA']];

    for (let i = 0; i < barrios.length; i++) {
        const barrio = barrios[i];
        console.log(`Procesando (${i + 1}/${barrios.length}): ${barrio.nombre}`);
        
        const { lat, lon } = await obtenerCoordenadas(barrio.nombre);
        filasParaSheets.push([barrio.nombre, lat, lon, barrio.tarifa]);

        // Pausa para no sobrecargar la API
        await new Promise(resolve => setTimeout(resolve, 1100));
    }

    console.log(`\n📦 Lista de ${filasParaSheets.length - 1} barrios preparada.`);

    try {
        const auth = new google.auth.GoogleAuth({
            keyFile: CREDENTIALS_PATH,
            scopes: ['https://www.googleapis.com/auth/spreadsheets'],
        });
        const client = await auth.getClient();
        console.log('🔑 Autenticación con Google exitosa.');

        await escribirEnGoogleSheets(client, filasParaSheets);
    } catch (error) {
        console.error('❌ Error en la autenticación con Google:', error.message);
    }

    console.log('🏁 Proceso finalizado.');
}

// --- 8. EJECUCIÓN ---
main();
